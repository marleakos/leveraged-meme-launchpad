FROM rust:1.75-slim

# Install Solana CLI
RUN apt-get update && apt-get install -y curl libssl-dev pkg-config && \
    curl -sL https://release.solana.com/v1.18.26/solana-release-x86_64-unknown-linux-gnu.tar.bz2 | tar -xjf - -C /usr/local --strip-components=1 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Anchor
RUN cargo install --git https://github.com/coral-xyz/anchor --tag v0.29.0 anchor-cli

WORKDIR /workspace
COPY . .

RUN anchor build
